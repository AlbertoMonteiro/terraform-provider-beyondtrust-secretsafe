# Stage 1: AOT publish for Alpine (musl) with statically linked OpenSSL.
# - openssl-libs-static is required by StaticOpenSslLinking=true (set in csproj).
# - gcompat provides a glibc compatibility layer so Grpc.Tools' glibc protoc binary
#   can run during the build. It is NOT included in the final binary.
FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build

RUN apk add --no-cache \
    clang gcc build-base \
    zlib-dev zlib-static \
    musl-dev cmake \
    openssl-dev openssl-libs-static \
    gcompat

WORKDIR /src
COPY BeyondTrust.SecretSafeProvider/ ./BeyondTrust.SecretSafeProvider/

RUN dotnet publish BeyondTrust.SecretSafeProvider/BeyondTrust.SecretSafeProvider.csproj \
    -c Release \
    -r linux-musl-x64 \
    --self-contained true \
    -o /publish

# Stage 2: run terraform plan against the provider
FROM hashicorp/terraform:latest

# Provider binary
COPY --from=build /publish/terraform-provider-beyondtrust-secretsafe /providers/terraform-provider-beyondtrust-secretsafe
RUN chmod +x /providers/terraform-provider-beyondtrust-secretsafe

# Configure dev_overrides so terraform uses the local binary instead of the registry
RUN printf 'provider_installation {\n  dev_overrides {\n    "beyondtrust/secretsafe" = "/providers"\n  }\n  direct {}\n}\n' \
    > /root/.terraformrc

# Terraform configuration
COPY terraform/ /workspace/
WORKDIR /workspace

# ENTRYPOINT ["/providers/terraform-provider-beyondtrust-secretsafe"]

ENTRYPOINT ["terraform", "plan"]
